<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE jasperReport PUBLIC "-//JasperReports//DTD Report Design//EN"
        "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">

<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="Expense_Report"
              pageWidth="842" pageHeight="595"
              orientation="Landscape"
              columnWidth="802" leftMargin="20" rightMargin="20"
              topMargin="15" bottomMargin="15">

    <!-- ==================== PARAMETERS ==================== -->
    <parameter name="dateFrom"      class="java.lang.String"/>
    <parameter name="dateTo"        class="java.lang.String"/>
    <parameter name="statusFilter"  class="java.lang.String"/>
    <parameter name="totalRecords"  class="java.lang.Integer"/>
    <parameter name="totalAmount"   class="java.lang.Double"/>
    <parameter name="totalApproved" class="java.lang.Double"/>
    <parameter name="totalPending"  class="java.lang.Double"/>

    <!-- ==================== FIELDS (from ExpenseReportRowDTO) ==================== -->
    <field name="expenseId"      class="java.lang.String"/>
    <field name="categoryName"   class="java.lang.String"/>
    <field name="paymentMethod"  class="java.lang.String"/>
    <field name="transactionId"  class="java.lang.String"/>
    <field name="paidTo"         class="java.lang.String"/>
    <field name="paidToCompany"  class="java.lang.String"/>
    <field name="employeeName"   class="java.lang.String"/>
    <field name="invoiceNo"      class="java.lang.String"/>
    <field name="amount"         class="java.math.BigDecimal"/>
    <field name="expenseDate"    class="java.time.LocalDate"/>
    <field name="description"    class="java.lang.String"/>
    <field name="status"         class="com.monaum.Rapid_Global.enums.Status"/>
    <field name="approvedAt"     class="java.time.LocalDateTime"/>
    <field name="createdByName"  class="java.lang.String"/>

    <!-- ==================== PAGE HEADER ==================== -->
    <pageHeader>
        <band height="110" splitType="Stretch">

            <line>
                <reportElement x="0" y="0" width="802" height="1"/>
                <graphicElement><pen lineWidth="3.0" lineColor="#1F3864"/></graphicElement>
            </line>

            <!-- Company Name -->
            <staticText>
                <reportElement x="0" y="6" width="400" height="30"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font size="22" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[RAPID GLOBAL]]></text>
            </staticText>

            <!-- Report Title badge -->
            <rectangle>
                <reportElement x="302" y="6" width="170" height="30" backcolor="#1F3864" mode="Opaque"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="302" y="6" width="170" height="30" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="14" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[EXPENSE REPORT]]></text>
            </staticText>

            <!-- Right address -->
            <staticText>
                <reportElement x="610" y="6" width="192" height="11"/>
                <textElement><font size="8" isBold="true"/></textElement>
                <text><![CDATA[683, West Shewrapara Busstand,]]></text>
            </staticText>
            <staticText>
                <reportElement x="610" y="17" width="192" height="11"/>
                <textElement><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Begum Rokeya Sharani, Mirpur, Dhaka-1216]]></text>
            </staticText>
            <staticText>
                <reportElement x="610" y="28" width="192" height="11"/>
                <textElement><font size="8" isBold="true"/></textElement>
                <text><![CDATA[☎ +8801718343943 | +8801675414022]]></text>
            </staticText>

            <line>
                <reportElement x="0" y="45" width="802" height="1"/>
                <graphicElement><pen lineWidth="2.0" lineColor="#1F3864"/></graphicElement>
            </line>

            <!-- Filter info -->
            <staticText>
                <reportElement x="0" y="52" width="70" height="18"/>
                <textElement verticalAlignment="Middle"><font isBold="true" size="9"/></textElement>
                <text><![CDATA[Date From:]]></text>
            </staticText>
            <textField>
                <reportElement x="70" y="52" width="110" height="18"/>
                <textElement verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$P{dateFrom}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="185" y="52" width="55" height="18"/>
                <textElement verticalAlignment="Middle"><font isBold="true" size="9"/></textElement>
                <text><![CDATA[Date To:]]></text>
            </staticText>
            <textField>
                <reportElement x="240" y="52" width="110" height="18"/>
                <textElement verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$P{dateTo}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="355" y="52" width="50" height="18"/>
                <textElement verticalAlignment="Middle"><font isBold="true" size="9"/></textElement>
                <text><![CDATA[Status:]]></text>
            </staticText>
            <textField>
                <reportElement x="405" y="52" width="100" height="18"/>
                <textElement verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$P{statusFilter}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="510" y="52" width="80" height="18"/>
                <textElement verticalAlignment="Middle"><font isBold="true" size="9"/></textElement>
                <text><![CDATA[Total Records:]]></text>
            </staticText>
            <textField>
                <reportElement x="590" y="52" width="60" height="18"/>
                <textElement verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$P{totalRecords}]]></textFieldExpression>
            </textField>

            <line>
                <reportElement x="0" y="78" width="802" height="1"/>
                <graphicElement><pen lineWidth="1.5" lineColor="#1F3864"/></graphicElement>
            </line>
        </band>
    </pageHeader>

    <!-- ==================== COLUMN HEADER ==================== -->
    <columnHeader>
        <band height="28">
            <rectangle>
                <reportElement x="0" y="0" width="802" height="28" backcolor="#1F3864" mode="Opaque"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="0"   y="0" width="28"  height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="8"/></textElement>
                <text><![CDATA[SL]]></text>
            </staticText>
            <staticText>
                <reportElement x="28"  y="0" width="70"  height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="8"/></textElement>
                <text><![CDATA[EXPENSE ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="98"  y="0" width="80"  height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="8"/></textElement>
                <text><![CDATA[CATEGORY]]></text>
            </staticText>
            <staticText>
                <reportElement x="178" y="0" width="75"  height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="8"/></textElement>
                <text><![CDATA[PAYMENT]]></text>
            </staticText>
            <staticText>
                <reportElement x="253" y="0" width="90"  height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="8"/></textElement>
                <text><![CDATA[PAID TO]]></text>
            </staticText>
            <staticText>
                <reportElement x="343" y="0" width="65"  height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="8"/></textElement>
                <text><![CDATA[EMPLOYEE]]></text>
            </staticText>
            <staticText>
                <reportElement x="408" y="0" width="65"  height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="8"/></textElement>
                <text><![CDATA[INVOICE NO]]></text>
            </staticText>
            <staticText>
                <reportElement x="473" y="0" width="70"  height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="8"/></textElement>
                <text><![CDATA[AMOUNT]]></text>
            </staticText>
            <staticText>
                <reportElement x="543" y="0" width="65"  height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="8"/></textElement>
                <text><![CDATA[DATE]]></text>
            </staticText>
            <staticText>
                <reportElement x="608" y="0" width="110" height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="8"/></textElement>
                <text><![CDATA[DESCRIPTION]]></text>
            </staticText>
            <staticText>
                <reportElement x="718" y="0" width="84"  height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="8"/></textElement>
                <text><![CDATA[STATUS]]></text>
            </staticText>
        </band>
    </columnHeader>

    <!-- ==================== DETAIL ==================== -->
    <detail>
        <band height="22" splitType="Stretch">

            <!-- Zebra stripe on even rows -->
            <rectangle>
                <reportElement x="0" y="0" width="802" height="22" backcolor="#DCE6F1" mode="Opaque">
                    <printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 == 0]]></printWhenExpression>
                </reportElement>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>

            <textField>
                <reportElement x="0"   y="0" width="28"  height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$V{REPORT_COUNT}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="28"  y="0" width="70"  height="22"/>
                <box leftPadding="3"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{expenseId}]]></textFieldExpression>
            </textField>
            <textField textAdjust="StretchHeight">
                <reportElement x="98"  y="0" width="80"  height="22"/>
                <box leftPadding="3"/>
                <textElement verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{categoryName} != null ? $F{categoryName} : "—"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="178" y="0" width="75"  height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{paymentMethod} != null ? $F{paymentMethod} : "—"]]></textFieldExpression>
            </textField>
            <textField textAdjust="StretchHeight">
                <reportElement x="253" y="0" width="90"  height="22"/>
                <box leftPadding="3"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{paidTo} != null ? $F{paidTo} : "—"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="343" y="0" width="65"  height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{employeeName} != null ? $F{employeeName} : "—"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="408" y="0" width="65"  height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{invoiceNo} != null ? $F{invoiceNo} : "—"]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="473" y="0" width="70"  height="22"/>
                <box rightPadding="4"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{amount}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="543" y="0" width="65"  height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{expenseDate} != null ? $F{expenseDate}.toString() : ""]]></textFieldExpression>
            </textField>
            <textField textAdjust="StretchHeight">
                <reportElement x="608" y="0" width="110" height="22"/>
                <box leftPadding="3"/>
                <textElement verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{description} != null ? $F{description} : "—"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="718" y="0" width="84"  height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{status} != null ? $F{status}.name() : ""]]></textFieldExpression>
            </textField>

            <line>
                <reportElement x="0" y="21" width="802" height="1"/>
                <graphicElement><pen lineWidth="0.3" lineColor="#CCCCCC"/></graphicElement>
            </line>
        </band>
    </detail>

    <!-- ==================== SUMMARY ==================== -->
    <summary>
        <band height="100" splitType="Stretch">

            <rectangle>
                <reportElement x="445" y="5" width="357" height="72" backcolor="#F2F2F2" mode="Opaque"/>
                <graphicElement><pen lineWidth="2.0" lineColor="#1F3864"/></graphicElement>
            </rectangle>

            <!-- Total Expenses — red to distinguish outflow from income -->
            <staticText>
                <reportElement x="450" y="10" width="130" height="18"/>
                <textElement verticalAlignment="Middle"><font isBold="true" size="10"/></textElement>
                <text><![CDATA[Total Expenses:]]></text>
            </staticText>
            <textField pattern="#,##0.00">
                <reportElement x="580" y="10" width="215" height="18" forecolor="#9C0006"/>
                <box rightPadding="10"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font isBold="true" size="12"/></textElement>
                <textFieldExpression><![CDATA[$P{totalAmount}]]></textFieldExpression>
            </textField>

            <!-- Approved -->
            <staticText>
                <reportElement x="450" y="30" width="130" height="18"/>
                <textElement verticalAlignment="Middle"><font isBold="true" size="10"/></textElement>
                <text><![CDATA[Approved:]]></text>
            </staticText>
            <textField pattern="#,##0.00">
                <reportElement x="580" y="30" width="215" height="18" forecolor="#375623"/>
                <box rightPadding="10"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font isBold="true" size="10"/></textElement>
                <textFieldExpression><![CDATA[$P{totalApproved}]]></textFieldExpression>
            </textField>

            <!-- Pending -->
            <staticText>
                <reportElement x="450" y="50" width="130" height="18"/>
                <textElement verticalAlignment="Middle"><font isBold="true" size="10"/></textElement>
                <text><![CDATA[Pending:]]></text>
            </staticText>
            <textField pattern="#,##0.00">
                <reportElement x="580" y="50" width="215" height="18" forecolor="#9C6500"/>
                <box rightPadding="10"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font isBold="true" size="10"/></textElement>
                <textFieldExpression><![CDATA[$P{totalPending}]]></textFieldExpression>
            </textField>

            <!-- Footer -->
            <staticText>
                <reportElement x="0" y="88" width="802" height="12"/>
                <textElement textAlignment="Center">
                    <font size="8" isBold="true" isItalic="true"/>
                </textElement>
                <text><![CDATA[RAPID GLOBAL  |  rapidglobal1971@gmail.com  |  +8801718343943]]></text>
            </staticText>
        </band>
    </summary>

</jasperReport>
