<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE jasperReport PUBLIC "-//JasperReports//DTD Report Design//EN"
        "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">

<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="Sales_Report"
              pageWidth="842" pageHeight="595"
              orientation="Landscape"
              columnWidth="802" leftMargin="20" rightMargin="20"
              topMargin="15" bottomMargin="15">

    <!-- ==================== PARAMETERS ==================== -->
    <parameter name="dateFrom"      class="java.lang.String"/>
    <parameter name="dateTo"        class="java.lang.String"/>
    <parameter name="statusFilter"  class="java.lang.String"/>
    <parameter name="totalOrders"   class="java.lang.Integer"/>
    <parameter name="totalSubAmount" class="java.lang.Double"/>
    <parameter name="totalDiscount"  class="java.lang.Double"/>
    <parameter name="totalVat"       class="java.lang.Double"/>
    <parameter name="totalAmount"    class="java.lang.Double"/>
    <parameter name="totalPaid"      class="java.lang.Double"/>
    <parameter name="totalDue"       class="java.lang.Double"/>

    <!-- ==================== FIELDS (from SalesReportRowDTO) ==================== -->
    <field name="invoiceNo"    class="java.lang.String"/>
    <field name="customerName" class="java.lang.String"/>
    <field name="phone"        class="java.lang.String"/>
    <field name="sellDate"     class="java.time.LocalDate"/>
    <field name="deliveryDate" class="java.time.LocalDate"/>
    <field name="itemCount"    class="java.lang.Integer"/>
    <field name="subTotal"     class="java.math.BigDecimal"/>
    <field name="discount"     class="java.math.BigDecimal"/>
    <field name="vat"          class="java.math.BigDecimal"/>
    <field name="totalAmount"  class="java.math.BigDecimal"/>
    <field name="paidAmount"   class="java.math.BigDecimal"/>
    <field name="dueAmount"    class="java.math.BigDecimal"/>
    <field name="status"       class="com.monaum.Rapid_Global.enums.OrderStatus"/>

    <!-- ==================== PAGE HEADER ==================== -->
    <pageHeader>
        <band height="110" splitType="Stretch">

            <!-- Top border -->
            <line>
                <reportElement x="0" y="0" width="802" height="1"/>
                <graphicElement><pen lineWidth="3.0" lineColor="#1F3864"/></graphicElement>
            </line>

            <!-- Company Name -->
            <staticText>
                <reportElement x="0" y="6" width="400" height="30"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font size="22" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[RAPID GLOBAL]]></text>
            </staticText>

            <!-- Report Title -->
            <rectangle>
                <reportElement x="302" y="6" width="160" height="30" backcolor="#1F3864" mode="Opaque"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="302" y="6" width="160" height="30" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="14" isBold="true" fontName="SansSerif"/>
                </textElement>
                <text><![CDATA[SALES REPORT]]></text>
            </staticText>

            <!-- Right address -->
            <staticText>
                <reportElement x="610" y="6" width="192" height="11"/>
                <textElement><font size="8" isBold="true"/></textElement>
                <text><![CDATA[683, West Shewrapara Busstand,]]></text>
            </staticText>
            <staticText>
                <reportElement x="610" y="17" width="192" height="11"/>
                <textElement><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Begum Rokeya Sharani, Mirpur, Dhaka-1216]]></text>
            </staticText>
            <staticText>
                <reportElement x="610" y="28" width="192" height="11"/>
                <textElement><font size="8" isBold="true"/></textElement>
                <text><![CDATA[☎ +8801718343943 | +8801675414022]]></text>
            </staticText>

            <!-- Divider -->
            <line>
                <reportElement x="0" y="45" width="802" height="1"/>
                <graphicElement><pen lineWidth="2.0" lineColor="#1F3864"/></graphicElement>
            </line>

            <!-- Filter Info Row -->
            <staticText>
                <reportElement x="0" y="52" width="70" height="18"/>
                <textElement verticalAlignment="Middle"><font isBold="true" size="9"/></textElement>
                <text><![CDATA[Date From:]]></text>
            </staticText>
            <textField>
                <reportElement x="70" y="52" width="110" height="18"/>
                <textElement verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$P{dateFrom}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="185" y="52" width="55" height="18"/>
                <textElement verticalAlignment="Middle"><font isBold="true" size="9"/></textElement>
                <text><![CDATA[Date To:]]></text>
            </staticText>
            <textField>
                <reportElement x="240" y="52" width="110" height="18"/>
                <textElement verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$P{dateTo}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="355" y="52" width="50" height="18"/>
                <textElement verticalAlignment="Middle"><font isBold="true" size="9"/></textElement>
                <text><![CDATA[Status:]]></text>
            </staticText>
            <textField>
                <reportElement x="405" y="52" width="100" height="18"/>
                <textElement verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$P{statusFilter}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="510" y="52" width="80" height="18"/>
                <textElement verticalAlignment="Middle"><font isBold="true" size="9"/></textElement>
                <text><![CDATA[Total Orders:]]></text>
            </staticText>
            <textField>
                <reportElement x="590" y="52" width="60" height="18"/>
                <textElement verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$P{totalOrders}]]></textFieldExpression>
            </textField>

            <!-- Divider -->
            <line>
                <reportElement x="0" y="78" width="802" height="1"/>
                <graphicElement><pen lineWidth="1.5" lineColor="#1F3864"/></graphicElement>
            </line>

        </band>
    </pageHeader>

    <!-- ==================== COLUMN HEADER ==================== -->
    <columnHeader>
        <band height="28">
            <rectangle>
                <reportElement x="0" y="0" width="802" height="28" backcolor="#1F3864" mode="Opaque"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="0"   y="0" width="30"  height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="9"/></textElement>
                <text><![CDATA[SL]]></text>
            </staticText>
            <staticText>
                <reportElement x="30"  y="0" width="80"  height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="9"/></textElement>
                <text><![CDATA[INVOICE NO]]></text>
            </staticText>
            <staticText>
                <reportElement x="110" y="0" width="120" height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="9"/></textElement>
                <text><![CDATA[CUSTOMER]]></text>
            </staticText>
            <staticText>
                <reportElement x="230" y="0" width="80"  height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="9"/></textElement>
                <text><![CDATA[PHONE]]></text>
            </staticText>
            <staticText>
                <reportElement x="310" y="0" width="70"  height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="9"/></textElement>
                <text><![CDATA[SELL DATE]]></text>
            </staticText>
            <staticText>
                <reportElement x="380" y="0" width="55"  height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="9"/></textElement>
                <text><![CDATA[ITEMS]]></text>
            </staticText>
            <staticText>
                <reportElement x="435" y="0" width="65"  height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="9"/></textElement>
                <text><![CDATA[SUBTOTAL]]></text>
            </staticText>
            <staticText>
                <reportElement x="500" y="0" width="55"  height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="9"/></textElement>
                <text><![CDATA[DISCOUNT]]></text>
            </staticText>
            <staticText>
                <reportElement x="555" y="0" width="55"  height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="9"/></textElement>
                <text><![CDATA[TOTAL]]></text>
            </staticText>
            <staticText>
                <reportElement x="610" y="0" width="55"  height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="9"/></textElement>
                <text><![CDATA[PAID]]></text>
            </staticText>
            <staticText>
                <reportElement x="665" y="0" width="55"  height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="9"/></textElement>
                <text><![CDATA[DUE]]></text>
            </staticText>
            <staticText>
                <reportElement x="720" y="0" width="82"  height="28" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="9"/></textElement>
                <text><![CDATA[STATUS]]></text>
            </staticText>
        </band>
    </columnHeader>

    <!-- ==================== DETAIL ==================== -->
    <detail>
        <band height="22" splitType="Stretch">

            <!-- Zebra stripe -->
            <rectangle>
                <reportElement x="0" y="0" width="802" height="22" backcolor="#DCE6F1" mode="Opaque">
                    <printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 == 0]]></printWhenExpression>
                </reportElement>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>

            <textField>
                <reportElement x="0"   y="0" width="30"  height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$V{REPORT_COUNT}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="30"  y="0" width="80"  height="22"/>
                <box leftPadding="4"/>
                <textElement textAlignment="Left" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{invoiceNo}]]></textFieldExpression>
            </textField>
            <textField textAdjust="StretchHeight">
                <reportElement x="110" y="0" width="120" height="22"/>
                <box leftPadding="4"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{customerName}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="230" y="0" width="80"  height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{phone}]]></textFieldExpression>
            </textField>
            <textField pattern="dd-MM-yyyy">
                <reportElement x="310" y="0" width="70"  height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{sellDate} != null ? $F{sellDate}.toString() : ""]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="380" y="0" width="55"  height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{itemCount}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="435" y="0" width="65"  height="22"/>
                <box rightPadding="4"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{subTotal}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="500" y="0" width="55"  height="22"/>
                <box rightPadding="4"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{discount}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="555" y="0" width="55"  height="22"/>
                <box rightPadding="4"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{totalAmount}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="610" y="0" width="55"  height="22"/>
                <box rightPadding="4"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{paidAmount}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="665" y="0" width="55"  height="22"/>
                <box rightPadding="4"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{dueAmount}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="720" y="0" width="82"  height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{status} != null ? $F{status}.name() : ""]]></textFieldExpression>
            </textField>

            <!-- Row divider -->
            <line>
                <reportElement x="0" y="21" width="802" height="1"/>
                <graphicElement><pen lineWidth="0.3" lineColor="#CCCCCC"/></graphicElement>
            </line>
        </band>
    </detail>

    <!-- ==================== SUMMARY ==================== -->
    <summary>
        <band height="90" splitType="Stretch">

            <!-- Totals box -->
            <rectangle>
                <reportElement x="435" y="5" width="367" height="60" backcolor="#F2F2F2" mode="Opaque"/>
                <graphicElement><pen lineWidth="2.0" lineColor="#1F3864"/></graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="440" y="10" width="130" height="18"/>
                <textElement verticalAlignment="Middle"><font isBold="true" size="10"/></textElement>
                <text><![CDATA[Grand Total:]]></text>
            </staticText>
            <textField pattern="#,##0.00">
                <reportElement x="570" y="10" width="225" height="18"/>
                <box rightPadding="10"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font isBold="true" size="12"/></textElement>
                <textFieldExpression><![CDATA[$P{totalAmount}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="440" y="30" width="130" height="18"/>
                <textElement verticalAlignment="Middle"><font isBold="true" size="10"/></textElement>
                <text><![CDATA[Total Paid:]]></text>
            </staticText>
            <textField pattern="#,##0.00">
                <reportElement x="570" y="30" width="225" height="18"/>
                <box rightPadding="10"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font isBold="true" size="10"/></textElement>
                <textFieldExpression><![CDATA[$P{totalPaid}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="440" y="50" width="130" height="18"/>
                <textElement verticalAlignment="Middle"><font isBold="true" size="10"/></textElement>
                <text><![CDATA[Total Due:]]></text>
            </staticText>
            <textField pattern="#,##0.00">
                <reportElement x="570" y="50" width="225" height="18"/>
                <box rightPadding="10"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font isBold="true" size="12"/></textElement>
                <textFieldExpression><![CDATA[$P{totalDue}]]></textFieldExpression>
            </textField>

            <!-- Footer -->
            <staticText>
                <reportElement x="0" y="78" width="802" height="12"/>
                <textElement textAlignment="Center">
                    <font size="8" isBold="true" isItalic="true"/>
                </textElement>
                <text><![CDATA[RAPID GLOBAL  |  rapidglobal1971@gmail.com  |  +8801718343943]]></text>
            </staticText>
        </band>
    </summary>

</jasperReport>
